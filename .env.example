# Environment Variables

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
# Optional but recommended: validates Telegram's webhook header.
TELEGRAM_WEBHOOK_SECRET=choose_a_long_random_value

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1...

# Server
PORT=3456
# Public HTTPS URL used by Telegram and Twilio, e.g. https://example.ngrok.app
APP_URL=https://your-public-url.example